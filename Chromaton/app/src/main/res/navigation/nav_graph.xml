<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.astronave.chromaton.ui.auth.LoginFragment"
        android:label="LoginFragment"
        tools:layout="@layout/fragment_login" >
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_loginFragment_to_lobbyFragment"
            app:destination="@id/lobbyFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/registerFragment"
        android:name="com.astronave.chromaton.ui.auth.RegisterFragment"
        android:label="registerFragment"
        tools:layout="@layout/fragment_register" >
        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_registerFragment_to_lobbyFragment"
            app:destination="@id/lobbyFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/lobbyFragment"
        android:name="com.astronave.chromaton.ui.lobby.LobbyFragment"
        android:label="Lobby"
        tools:layout="@layout/fragment_lobby" >

        <action
            android:id="@+id/action_lobbyFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_lobbyFragment_to_waitingRoomFragment"
            app:destination="@id/waitingRoomFragment"/>
    </fragment>
    <fragment
        android:id="@+id/waitingRoomFragment"
        android:name="com.astronave.chromaton.ui.lobby.WaitingRoomFragment"
        android:label="Waiting Room">

        <argument
            android:name="gameId"
            app:argType="integer" />
        <argument
            android:name="isHost"
            app:argType="boolean" />
        <action
            android:id="@+id/action_waitingRoom_to_gameFragment"
            app:destination="@id/gameFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />
    </fragment>
    <fragment
        android:id="@+id/gameFragment"
        android:name="com.astronave.chromaton.ui.game.GameFragment"
        android:label="Partida en curso"
        tools:layout="@layout/fragment_game" />

</navigation>